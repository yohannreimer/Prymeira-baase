BAASE_RUNTIME_MODE=pilot
BAASE_SEED_DEMO_DATA=false
BAASE_AUTH_MODE=local
PRYMEIRA_ACCOUNT_API_URL=https://hub.prymeiradigital.com.br/api
DATABASE_URL=postgres://baase:baase@localhost:5432/baase
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
PORT=3090
HOST=0.0.0.0
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=prymeira-baase
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
# O bucket deve ter lifecycle habilitado para abortar multipart incompleto em workspaces/ em ate 1 dia.
BAASE_RESET_WORKSPACE_ID=workspace_a
