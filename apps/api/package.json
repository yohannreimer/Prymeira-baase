{
  "name": "@prymeira/baase-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "db:init": "tsx src/db/init.ts",
    "db:migrate-operational": "tsx src/db/migrate-operational.ts",
    "db:reset:workspace": "tsx src/db/reset-workspace.ts",
    "test": "vitest run",
    "test:postgres-schema": "node -e \"if (!process.env.TEST_DATABASE_URL) { console.error('TEST_DATABASE_URL is required'); process.exit(1); }\" && vitest run src/db/operational-schema.postgres.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@deepgram/sdk": "^5.5.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^10.1.0",
    "@prymeira/baase-shared": "workspace:*",
    "dotenv": "^17.4.2",
    "fastify": "^5.6.2",
    "ipaddr.js": "^2.2.0",
    "openai": "^6.45.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "pg-mem": "^3.0.14",
    "tsx": "^4.20.6",
    "vitest": "^3.2.4"
  }
}
